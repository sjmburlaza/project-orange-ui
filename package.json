{
  "name": "project-orange-v2",
  "version": "0.0.0",
  "workspaces": [
    "libs/models",
    "libs/shared",
    "libs/ui",
    "libs/core"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve project-orange-storefront --proxy-config proxy.conf.cjs",
    "mock:api": "node mock-api/server.cjs",
    "start:e2e": "ng serve project-orange-storefront --configuration e2e",
    "build": "ng build project-orange-storefront",
    "build:libs": "ng build orange-models && ng build orange-shared && ng build orange-ui && ng build orange-core",
    "build:all": "npm run build:libs && ng build project-orange-storefront && ng build project-orange-admin",
    "watch": "ng build project-orange-storefront --watch --configuration development",
    "test": "ng test project-orange-storefront",
    "test:watch": "ng test project-orange-storefront --watch",
    "test:ci": "ng test project-orange-storefront --watch=false",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "lint": "ng lint project-orange-storefront",
    "lint:libs": "ng lint orange-models && ng lint orange-shared && ng lint orange-ui && ng lint orange-core",
    "dev:ssr": "ng serve project-orange-storefront",
    "build:ssr": "ng build project-orange-storefront",
    "serve:ssr:project-orange-storefront": "node dist/project-orange-storefront/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-server": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/ssr": "^20.3.26",
    "@ngrx/effects": "^20.1.0",
    "@ngrx/store": "^20.1.0",
    "@ngrx/store-devtools": "^20.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "ng2-charts": "^9.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.0.3",
    "@angular/cli": "^20.0.3",
    "@angular/compiler-cli": "^20.0.0",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^3.2.6",
    "angular-eslint": "21.0.1",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.1",
    "jsdom": "^29.1.1",
    "json-server": "^0.17.4",
    "ng-packagr": "^20.3.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "8.46.4",
    "vitest": "^3.2.6"
  }
}
