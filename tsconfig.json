/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@orange/core": [
        "./libs/core/public-api.ts"
      ],
      "@orange/models": [
        "./libs/models/public-api.ts"
      ],
      "@orange/shared": [
        "./libs/shared/public-api.ts"
      ],
      "@orange/ui": [
        "./libs/ui/public-api.ts"
      ],
      "src/*": [
        "./projects/storefront/src/*"
      ]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/storefront/tsconfig.app.json"
    },
    {
      "path": "./projects/storefront/tsconfig.spec.json"
    },
    {
      "path": "./tsconfig.e2e.json"
    },
    {
      "path": "./projects/admin/tsconfig.app.json"
    },
    {
      "path": "./projects/admin/tsconfig.spec.json"
    },
    {
      "path": "./libs/models/tsconfig.lib.json"
    },
    {
      "path": "./libs/shared/tsconfig.lib.json"
    },
    {
      "path": "./libs/ui/tsconfig.lib.json"
    },
    {
      "path": "./libs/core/tsconfig.lib.json"
    }
  ]
}
